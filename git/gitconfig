[user]
	name = Evan Wheeler
	email = evan.wheeler87@gmail.com

[push]
        autoSetupRemote = true
# Alternate identities
[include]
	path = ~/.gitidentities/identities

[credential]
	helper = osxkeychain

[init]
	defaultBranch = main

[pager]
	branch = false
[core]
	excludesfile = ~/dotfiles/git/gitignore
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
	syntax-theme = OneHalfDark

[merge]
	conflictstyle = zdiff3

[diff]
	colorMoved = default
