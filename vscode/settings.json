{
  "atomKeymap.promptV3Features": true,
  "editor.multiCursorModifier": "alt",
  "editor.formatOnPaste": true,
  "python.venvPath": "~/.virtualenvs",
  "workbench.startupEditor": "newUntitledFile",
  "python.linting.flake8Enabled": true,
  "python.linting.mypyEnabled": true,
  "python.linting.banditEnabled": true,
  "workbench.editorAssociations": {
    "*.ipynb": "jupyter.notebook.ipynb",
  },
  "python.formatting.provider": "none",
  "editor.tabCompletion": "on",
  "editor.acceptSuggestionOnEnter": "off",
  "terminal.integrated.shell.osx": "/bin/zsh",
  "python.showStartPage": false,
  "python.linting.flake8Args": ["--max-line-length=119"],
  "python.linting.pylintPath": ".",
  "[ruby]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
  },
  "liveshare.authenticationProvider": "GitHub",
  "security.workspace.trust.untrustedFiles": "open",
  "ruby.codeCompletion": "rcodetools",
  "go.toolsManagement.autoUpdate": true,
  "redhat.telemetry.enabled": false,
  "editor.minimap.enabled": false,
  "ruff.lint.run": "onSave",
  "claudeCode.preferredLocation": "sidebar",
  "viraTheme.accent": "Indigo",
  "workbench.colorCustomizations": {
    "[Vira*]": {
      "statusBar.debuggingBackground": "#758AFF33",
      "statusBar.debuggingForeground": "#758AFF",
      "toolbar.activeBackground": "#758AFF26",
      "button.background": "#758AFF",
      "button.hoverBackground": "#758AFFcc",
      "activityBarBadge.background": "#758AFF",
      "activityBar.activeBorder": "#758AFF",
      "activityBarTop.activeBorder": "#758AFF",
      "list.inactiveSelectionIconForeground": "#758AFF",
      "list.activeSelectionForeground": "#758AFF",
      "list.inactiveSelectionForeground": "#758AFF",
      "list.highlightForeground": "#758AFF",
      "sash.hoverBorder": "#758AFF80",
      "list.activeSelectionIconForeground": "#758AFF",
      "scrollbarSlider.activeBackground": "#758AFF80",
      "editorSuggestWidget.highlightForeground": "#758AFF",
      "textLink.foreground": "#758AFF",
      "progressBar.background": "#758AFF",
      "pickerGroup.foreground": "#758AFF",
      "tab.activeBorder": "#758AFF",
      "tab.activeBorderTop": "#758AFF00",
      "tab.unfocusedActiveBorder": "#758AFF",
      "tab.unfocusedActiveBorderTop": "#758AFF00",
      "tab.activeModifiedBorder": "#758AFF00",
      "notificationLink.foreground": "#758AFF",
      "editorWidget.resizeBorder": "#758AFF",
      "editorWidget.border": "#758AFF",
      "settings.modifiedItemIndicator": "#758AFF",
      "panelTitle.activeBorder": "#758AFF",
      "menu.selectionForeground": "#758AFF",
      "menubar.selectionForeground": "#758AFF",
      "editor.findMatchBorder": "#758AFF",
      "selection.background": "#758AFF40",
      "statusBarItem.remoteBackground": "#758AFF14",
      "statusBarItem.remoteHoverBackground": "#758AFF",
      "statusBarItem.remoteForeground": "#758AFF",
      "notebook.inactiveFocusedCellBorder": "#758AFF80",
      "commandCenter.activeBorder": "#758AFF80",
      "chat.slashCommandForeground": "#758AFF",
      "chat.avatarForeground": "#758AFF",
      "activityBarBadge.foreground": "#000000",
      "button.foreground": "#000000",
      "statusBarItem.remoteHoverForeground": "#000000",
      "breadcrumb.activeSelectionForeground": "#758AFF",
      "extensionButton.separator": "#758AFF33",
      "extensionButton.background": "#758AFF14",
      "extensionButton.foreground": "#758AFF",
      "extensionButton.hoverBackground": "#758AFF33",
      "extensionButton.prominentForeground": "#758AFF",
      "extensionButton.prominentBackground": "#758AFF14",
      "extensionButton.prominentHoverBackground": "#758AFF33",
    },
    "tab.activeForeground": "#FFFFFF",
    "tab.inactiveForeground": "#676767",
    "tab.unfocusedActiveForeground": "#FFFFFF",
    "tab.activeModifiedForeground": "#FFFFFF",
    "tab.inactiveModifiedForeground": "#676767",
    "tab.unfocusedActiveModifiedForeground": "#FFFFFF",
    "list.activeSelectionForeground": "#D9D9D9",
    "list.inactiveSelectionForeground": "#D9D9D9",
    "list.hoverForeground": "#D9D9D9",
    "list.focusForeground": "#D9D9D9",
    "tree.inactiveIndentGuidesStroke": "#424242",
    "breadcrumb.foreground": "#CCCCCC",
    "breadcrumb.focusForeground": "#FFFFFF",
    "breadcrumb.activeSelectionForeground": "#758AFF",
    "breadcrumbPicker.background": "#1E1E1E",
    "gitDecoration.modifiedResourceForeground": "#E6DB74",
    "gitDecoration.untrackedResourceForeground": "#E6DB74",
    "gitDecoration.addedResourceForeground": "#00ff00",
    "gitDecoration.stageModifiedResourceForeground": "#00ff00",
    "gitDecoration.stageAddedResourceForeground": "#00ff00",
    "editorError.foreground": "#D9D9D9",
    "editorWarning.foreground": "#D9D9D9",
    "list.errorForeground": "#D9D9D9",
    "list.warningForeground": "#D9D9D9",
    "editorGutter.modifiedBackground": "#E6DB74",
    "editorGutter.addedBackground": "#A6E22E",
    "editorGutter.deletedBackground": "#F92672",
  },
  "workbench.iconTheme": "vira-icons-graphene",
  "openInGitHub.defaultBranch": "main",
  "eslint.codeActionsOnSave.options": {},
  "breadcrumbs.filePath": "on",
  "breadcrumbs.symbolPath": "on",
  "scm.diffDecorations": "all",
  "scm.diffDecorationsGutterVisibility": "always",
  "window.title": "${dirty}${activeEditorMedium}${separator}${rootName}",
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "claudeCode.selectedModel": "default",
  "gitlens.showWhatsNewAfterUpgrades": false,
  "gitlens.currentLine.enabled": false,
  "gitlens.codeLens.authors.enabled": false,
  "gitlens.codeLens.enabled": false,
  "gitlens.codeLens.recentChange.enabled": false,
  "gitlens.hovers.enabled": false,
  "gitlens.hovers.avatars": false,
  "gitlens.hovers.pullRequests.enabled": false,
  "gitlens.hovers.autolinks.enabled": false,
  "workbench.editor.enablePreview": false,
}
