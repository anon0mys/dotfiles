{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(npm test:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run lint-server:*)",
      "Bash(npm run lint-client:*)",
      "Bash(nvm use)",
      "Bash(node --version)",
      "Bash(npx prettier:*)",
      "Bash(npm exec prettier:*)",
      "Bash(npx tsc:*)",
      "Bash(npx eslint:*)",
      "Bash(gt log:*)",
      "Bash(gh:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git worktree list:*)",
      "Bash(git stash list:*)",
      "Bash(git remote:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(git blame:*)",
      "Bash(git shortlog:*)",
      "Bash(git describe:*)",
      "Bash(git tag:*)",
      "Bash(git config:*)",
      "Bash(wc:*)",
      "Bash(docker:*)",
      "Agent"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-status needs-input"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-status working"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-status idle"
          }
        ]
      }
    ]
  }
}
